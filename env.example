# CrawlDoctor Environment Configuration

# Application
CRAWLDOCTOR_APP_NAME="CrawlDoctor"
CRAWLDOCTOR_APP_VERSION="1.0.0"
CRAWLDOCTOR_DEBUG=false
CRAWLDOCTOR_ENVIRONMENT="production"

# API Configuration
CRAWLDOCTOR_API_HOST="0.0.0.0"
CRAWLDOCTOR_API_PORT=8000
CRAWLDOCTOR_API_PREFIX="/api/v1"

# Database Configuration
CRAWLDOCTOR_DATABASE_URL="postgresql://user:password@localhost:5432/crawldoctor"
CRAWLDOCTOR_DATABASE_POOL_SIZE=20
CRAWLDOCTOR_DATABASE_MAX_OVERFLOW=10

# Redis Configuration (set redis://... to enable)
CRAWLDOCTOR_REDIS_URL="memory://localhost"
CRAWLDOCTOR_REDIS_TTL=3600

# Security Configuration
CRAWLDOCTOR_SECRET_KEY="your-super-secret-key-change-this-in-production"
CRAWLDOCTOR_ALGORITHM="HS256"
CRAWLDOCTOR_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin User Configuration
CRAWLDOCTOR_ADMIN_USERNAME="admin"
CRAWLDOCTOR_ADMIN_PASSWORD="admin123"
CRAWLDOCTOR_ADMIN_EMAIL="admin@crawldoctor.com"

# Rate Limiting
CRAWLDOCTOR_RATE_LIMIT_REQUESTS=1000
CRAWLDOCTOR_RATE_LIMIT_WINDOW=60

# CORS Configuration
CRAWLDOCTOR_CORS_ORIGINS='["http://localhost:3000", "https://yourdomain.com"]'

# GeoIP Configuration (optional)
CRAWLDOCTOR_GEOIP_DATABASE_PATH="/path/to/GeoLite2-City.mmdb"

# Tracking Configuration
CRAWLDOCTOR_PIXEL_CACHE_TTL=86400
CRAWLDOCTOR_MAX_REFERRER_LENGTH=2000
CRAWLDOCTOR_MAX_USER_AGENT_LENGTH=500
CRAWLDOCTOR_MAX_PAGE_URL_LENGTH=2000

# Event Batching
CRAWLDOCTOR_EVENT_BATCH_ENABLED=true
CRAWLDOCTOR_EVENT_BATCH_SIZE=200
CRAWLDOCTOR_EVENT_BATCH_MAX_DELAY_MS=250
CRAWLDOCTOR_EVENT_BATCH_MAX_QUEUE=5000

# Event Partitioning
CRAWLDOCTOR_EVENT_PARTITION_DAYS_AHEAD=2
CRAWLDOCTOR_EVENT_PARTITION_DAYS_BACK=1

# Analytics Configuration
CRAWLDOCTOR_ANALYTICS_BATCH_SIZE=1000
CRAWLDOCTOR_ANALYTICS_RETENTION_DAYS=365

# Monitoring Configuration
CRAWLDOCTOR_ENABLE_METRICS=true
CRAWLDOCTOR_METRICS_PORT=8001

# External API Configuration
CRAWLDOCTOR_EXPORT_API_ENABLED=true
CRAWLDOCTOR_EXPORT_API_KEYS='["your-export-api-key-1", "your-export-api-key-2"]'

# Frontend Configuration (for development)
REACT_APP_API_URL="http://localhost:8000"
